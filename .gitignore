# --- DEPENDENCIES ---
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- NEXT.JS & BUILD ---
/.next/
/out/
/build
*.tsbuildinfo
next-env.d.ts

# --- DATABASE & SECRETS (CRITICAL) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Ignore local SQLite databases (if used for testing)
*.db
*.db-journal

# Ignore Prisma Client if you've redirected its output
/src/generated/prisma

# --- LOGS & DEBUG ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs
*.log

# --- SYSTEM FILES ---
.DS_Store
Thumbs.db
*.pem

# --- VERCEL ---
.vercel