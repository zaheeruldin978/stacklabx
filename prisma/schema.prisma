// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Note: URL intentionally removed for Prisma 7+ Adapter Architecture. 
  // Connection is now handled securely in src/lib/db.ts
}

// ==========================================
// THE UNIFIED ENTERPRISE LEAD ENGINE
// ==========================================
model Lead {
  id           String   @id @default(uuid())
  email        String

  // Standard Contact Info (Optional for Calculator Leads)
  name         String?
  company      String?
  service      String?   // e.g., "AI Automation", "Web Dev"
  budget       String?
  status       String    @default("NEW") // NEW, CONTACTED, CLOSED

  // Telemetry Data (Optional for Standard Contact Leads)
  traffic      Int?      // API Requests in thousands
  db    Size       Int?      // Database size in GB
  computeType  String?   // Serverless vs Dedicated
  standardCost Int?
  stacklabCost Int?
  source       String    @default("Global Network")

  createdAt    DateTime  @default(now())
}

// ==========================================
// ACADEMY & CONTENT MODELS
// ==========================================
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())
}

enum Role {
  STUDENT
  ADMIN
}

model Post {
  id        String   @id @default(cuid())
  wpId      Int      @unique // To keep track of the original WordPress ID
  title     String
  content   String   @db.Text // Use Text type for long articles
  excerpt   String   @db.Text
  slug      String   @unique
  date      String
  image     String?
  createdAt DateTime @default(now())
}