generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// THE UNIFIED ENTERPRISE LEAD ENGINE
// ==========================================
model Lead {
  id           String   @id @default(uuid())
  email        String

  // Standard Contact Info
  name         String?
  company      String?
  service      String?   
  budget       String?
  status       String   @default("NEW")

  // Telemetry Data
  traffic      Int?      
  dbSize       Int?      
  computeType  String?   
  standardCost Int?
  stacklabCost Int?
  source       String   @default("Global Network")

  // --- RECOVERY VAULT FLAG ---
  isDeleted    Boolean  @default(false)

  createdAt    DateTime @default(now())
}

// ==========================================
// ACADEMY & CONTENT MODELS
// ==========================================
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())
}

enum Role {
  STUDENT
  ADMIN
}

model Post {
  id        String   @id @default(cuid())
  wpId      Int      @unique 
  title     String
  content   String   @db.Text 
  excerpt   String   @db.Text
  slug      String   @unique
  date      String
  image     String?
  
  // --- RECOVERY VAULT FLAG ---
  isDeleted Boolean  @default(false)
  
  createdAt DateTime @default(now())
}